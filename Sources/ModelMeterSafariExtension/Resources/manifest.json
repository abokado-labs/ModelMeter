{
  "manifest_version": 3,
  "name": "Model Meter",
  "description": "Captures Gemini usage percentages from gemini.google.com/usage for Model Meter.",
  "version": "1.0",
  "background": {
    "scripts": ["background.js"],
    "type": "module"
  },
  "content_scripts": [{
    "js": ["content.js"],
    "matches": ["https://gemini.google.com/usage*"],
    "run_at": "document_idle"
  }],
  "host_permissions": [
    "https://gemini.google.com/*"
  ],
  "permissions": [
    "alarms",
    "nativeMessaging"
  ]
}
